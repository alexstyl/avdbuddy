# GitHub release publishing
GITHUB_TOKEN=ghp_xxx
# GH_TOKEN=ghp_xxx
RELEASE_REPO=alexstyl/avdbuddy

# macOS notarization
NOTARY_APPLE_ID=you@example.com
NOTARY_TEAM_ID=XXXXXXXXXX
NOTARY_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Optional: override the Developer ID Application certificate name picked by the script
# RELEASE_SIGN_IDENTITY=Developer ID Application: Your Name (TEAMID)
